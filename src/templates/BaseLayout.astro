---
import "../styles/global.css";

const {
  title,
  description = "Maquette privee de site vitrine local.",
  primaryColor = "#162033",
  accentColor = "#d89c62"
} = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body style={`--primary:${primaryColor};--accent:${accentColor};`}>
    <slot />
  </body>
</html>
